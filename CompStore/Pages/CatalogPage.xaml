<Page x:Class="CompStore.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CatalogPage"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя шапка -->
        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock Text="CompStore"
                               Style="{StaticResource PageTitleStyle}"/>
                    <TextBlock x:Name="tbWelcome"
                               Text="Добро пожаловать"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           ItemHeight="56">
                    <Button x:Name="btnProfile"
                            Content="Профиль"
                            Width="105"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="btnProfile_Click"/>

                    <Button x:Name="btnCart"
                            Content="Корзина"
                            Width="105"
                            Style="{StaticResource MainButtonStyle}"
                            Click="btnCart_Click"/>

                    <Button x:Name="btnQr"
                            Content="Поддержка"
                            Width="125"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="btnQr_Click"/>

                    <Button x:Name="btnAdmin"
                            Content="Админ"
                            Width="105"
                            Visibility="Collapsed"
                            Style="{StaticResource GhostButtonStyle}"
                            Click="btnAdmin_Click"/>

                    <Button x:Name="btnExit"
                            Content="Выйти"
                            Width="105"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="btnExit_Click"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Фильтры -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="0,14,0,14"
                Padding="18">

            <DockPanel LastChildFill="False">

                <!-- Плашка справа -->
                <Border DockPanel.Dock="Right"
                        Background="#F4F1FF"
                        CornerRadius="18"
                        Padding="12,8"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                    <TextBlock Text="Каталог ПК и комплектующих"
                               Foreground="{StaticResource AccentBrush}"
                               FontWeight="SemiBold"/>
                </Border>

                <!-- Фильтры слева -->
                <WrapPanel VerticalAlignment="Center">

                    <StackPanel Width="0"/>

                    <StackPanel Width="180"
                                Margin="0,0,12,0">
                        <TextBlock Text="Поиск"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBox x:Name="txtSearch"
                                 Style="{StaticResource MainTextBoxStyle}"
                                 Margin="0,6,0,0"
                                 TextChanged="txtSearch_TextChanged"/>
                    </StackPanel>

                    <StackPanel Width="190"
                                Margin="0,0,12,0">
                        <TextBlock Text="Категория"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                        <ComboBox x:Name="cmbCategory"
                                  Style="{StaticResource MainComboBoxStyle}"
                                  Margin="0,6,0,0"
                                  SelectionChanged="cmbCategory_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Width="190"
                                Margin="0,0,12,0">
                        <TextBlock Text="Сортировка"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                        <ComboBox x:Name="cmbSort"
                                  Style="{StaticResource MainComboBoxStyle}"
                                  Margin="0,6,0,0"
                                  SelectionChanged="cmbSort_SelectionChanged"/>
                    </StackPanel>

                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- Карточки -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="lvProducts">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="390"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorderStyle}"
                                Width="370"
                                Height="310"
                                Background="White">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="#F8FAFF"
                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Margin="0,0,14,0">
                                        <Image Source="{Binding ImagePath}"
                                               Width="86"
                                               Height="86"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding ProductName}"
                                                       Foreground="{StaticResource TextMainBrush}"
                                                       FontSize="17"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="46"/>

                                            <Border Grid.Column="1"
                                                    Background="#F4F1FF"
                                                    CornerRadius="14"
                                                    Padding="8,4"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding StatusName}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="{Binding Model, StringFormat=Модель: {0}}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,8,0,0"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Text="{Binding Price, StringFormat=Цена: {0} ₽}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="21"
                                                   FontWeight="Bold"
                                                   Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Grid.Row="1"
                                            Margin="0,10,0,0">
                                    <TextBlock Text="{Binding CpuInfo, StringFormat=CPU: {0}}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Text="{Binding GpuInfo, StringFormat=GPU: {0}}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12"
                                               Margin="0,6,0,0"
                                               TextTrimming="CharacterEllipsis"/>

                                    <WrapPanel Margin="0,12,0,0">
                                        <Border Background="#EEF2FF"
                                                CornerRadius="12"
                                                Padding="8,3"
                                                Margin="0,0,8,0">
                                            <TextBlock Text="{Binding WarrantyMonths, StringFormat=Гарантия {0} мес.}"
                                                       Foreground="#4F46E5"
                                                       FontSize="12"/>
                                        </Border>

                                        <Border Background="#FAF5FF"
                                                CornerRadius="12"
                                                Padding="8,3">
                                            <TextBlock Text="{Binding ComputerType}"
                                                       Foreground="#9333EA"
                                                       FontSize="12"/>
                                        </Border>
                                    </WrapPanel>

                                    <TextBlock Text="{Binding ShortSpecifications}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,14,0,0"
                                               MaxHeight="42"/>
                                </StackPanel>

                                <Grid Grid.Row="2"
                                      Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="В корзину"
                                            Tag="{Binding SourceProduct}"
                                            Height="34"
                                            Width="110"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource MainButtonStyle}"
                                            Click="btnAddToCart_Click"/>

                                    <Button Grid.Column="2"
                                            Content="Подробнее"
                                            Tag="{Binding SourceProduct}"
                                            Height="34"
                                            Width="110"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Click="btnDetails_Click"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>