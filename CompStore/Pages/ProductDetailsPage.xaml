<Page x:Class="CompStore.Pages.ProductDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ProductDetailsPage"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Карточка товара"
                       Style="{StaticResource PageTitleStyle}"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Content="Назад"
                    Width="100"
                    Style="{StaticResource GhostButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="btnBack_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <Border Background="#F8FAFF"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="16"
                            Margin="0,0,0,16">
                        <Image x:Name="imgMain"
                               Width="340"
                               Height="340"
                               Stretch="Uniform"/>
                    </Border>

                    <TextBlock Text="Изображения"
                               Foreground="{StaticResource TextMainBrush}"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Height="110">
                        <ItemsControl x:Name="icImages">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Tag="{Binding}"
                                            Click="btnThumbnail_Click"
                                            Width="90"
                                            Height="90"
                                            Margin="4"
                                            Style="{StaticResource GhostButtonStyle}">
                                        <Image Source="{Binding}"
                                               Width="68"
                                               Height="68"
                                               Stretch="Uniform"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="16,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="tbName"
                                   Foreground="{StaticResource TextMainBrush}"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="tbModel"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="18"
                                   Margin="0,10,0,0"/>

                        <TextBlock x:Name="tbPrice"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,18,0,0"/>

                        <WrapPanel Margin="0,18,0,0">
                            <Border Background="#F4F1FF" CornerRadius="14" Padding="10,5" Margin="0,0,10,10">
                                <TextBlock x:Name="tbCategory" Foreground="{StaticResource AccentBrush}"/>
                            </Border>
                            <Border Background="#EEF2FF" CornerRadius="14" Padding="10,5" Margin="0,0,10,10">
                                <TextBlock x:Name="tbBrand" Foreground="#4F46E5"/>
                            </Border>
                            <Border Background="#FAF5FF" CornerRadius="14" Padding="10,5" Margin="0,0,10,10">
                                <TextBlock x:Name="tbStatus" Foreground="#9333EA"/>
                            </Border>
                        </WrapPanel>

                        <TextBlock x:Name="tbQuantity" Foreground="{StaticResource TextMutedBrush}" Margin="0,10,0,0"/>
                        <TextBlock x:Name="tbWarranty" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                        <TextBlock x:Name="tbComputerType" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                        <TextBlock x:Name="tbCpu" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                        <TextBlock x:Name="tbGpu" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                        <TextBlock x:Name="tbRam" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>
                        <TextBlock x:Name="tbStorage" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0"/>

                        <TextBlock Text="Описание"
                                   Foreground="{StaticResource TextMainBrush}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,24,0,8"/>

                        <TextBlock x:Name="tbDescription"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Характеристики"
                                   Foreground="{StaticResource TextMainBrush}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,24,0,8"/>

                        <Border Background="#F8FAFF"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="14">
                            <TextBlock x:Name="tbSpecifications"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Button x:Name="btnAddToCart"
                                Content="Добавить в корзину"
                                Width="190"
                                Margin="0,24,0,0"
                                Style="{StaticResource MainButtonStyle}"
                                Click="btnAddToCart_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>