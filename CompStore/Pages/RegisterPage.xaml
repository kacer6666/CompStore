<Page x:Class="CompStore.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="RegisterPage"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*"/>
            <ColumnDefinition Width="0.95*"/>
        </Grid.ColumnDefinitions>

        <!-- Инфо -->
        <Grid Grid.Column="0">
            <Border Style="{StaticResource CardBorderStyle}"
                    Margin="0,40,20,40">
                <StackPanel Margin="24" VerticalAlignment="Center">
                    <TextBlock Text="Создание аккаунта"
                               FontSize="38"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMainBrush}"/>

                    <TextBlock Text="После регистрации будут доступны каталог, корзина, история заказов и электронные чеки."
                               FontSize="18"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,16,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Форма -->
        <Grid Grid.Column="1">
            <Border Style="{StaticResource CardBorderStyle}"
                    Width="450"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Регистрация"
                               Style="{StaticResource PageTitleStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Введите данные пользователя"
                               Style="{StaticResource MutedTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,24"/>

                    <TextBlock Text="Имя" Foreground="{StaticResource TextMainBrush}"/>
                    <TextBox x:Name="txtName" Style="{StaticResource MainTextBoxStyle}" MaxLength="100"/>

                    <TextBlock Text="Логин" Foreground="{StaticResource TextMainBrush}"/>
                    <TextBox x:Name="txtLogin" Style="{StaticResource MainTextBoxStyle}" MaxLength="50"/>

                    <TextBlock Text="Пароль" Foreground="{StaticResource TextMainBrush}"/>
                    <PasswordBox x:Name="txtPassword" Style="{StaticResource MainPasswordBoxStyle}" MaxLength="50"/>

                    <TextBlock Text="Повтор пароля" Foreground="{StaticResource TextMainBrush}"/>
                    <PasswordBox x:Name="txtPasswordRepeat" Style="{StaticResource MainPasswordBoxStyle}" MaxLength="50"/>

                    <TextBlock Text="Email" Foreground="{StaticResource TextMainBrush}"/>
                    <TextBox x:Name="txtEmail" Style="{StaticResource MainTextBoxStyle}" MaxLength="100"/>

                    <TextBlock Text="Телефон" Foreground="{StaticResource TextMainBrush}"/>
                    <TextBox x:Name="txtPhone" Style="{StaticResource MainTextBoxStyle}" MaxLength="20"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0">
                        <Button x:Name="btnRegister"
                                Content="Зарегистрироваться"
                                Width="180"
                                Style="{StaticResource MainButtonStyle}"
                                Margin="0,0,10,0"
                                Click="btnRegister_Click"/>

                        <Button x:Name="btnBack"
                                Content="Назад"
                                Width="110"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="btnBack_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>